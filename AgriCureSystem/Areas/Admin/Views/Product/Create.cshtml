@model CategoryWithBrandVM

<div class="container">
    <div class="row mb-3 align-items-center my-3">
        <div class="col-md-12">
            <h2 class="display-6">Create New Product</h2>
        </div>
    </div>

    <div class="row my-3">
        <div class="col-12">
            <form method="post" enctype="multipart/form-data">

                <div class="mb-3">
                    <label asp-for="Product.Name" class="form-label">Name</label>
                    <input type="text" class="form-control" asp-for="Product.Name">
                    <span class="text-danger" asp-validation-for="Product.Name"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Product.Description" class="form-label">Description</label>
                    <div class="form-floating">
                        <textarea class="form-control" placeholder="Leave a description here" style="height: 100px" asp-for="Product.Description"></textarea>
                        <label>Your Description Here...</label>
                    </div>
                    <span class="text-danger" asp-validation-for="Product.Description"></span>
                </div>

                <div class="mb-3">
                    <label for="mainImg" class="form-label">Main Image</label>
                    <input type="file" class="form-control" id="mainImg" name="mainImg" accept="image/*" onchange="previewImage(event)">
                    <img id="imagePreview" src="#" alt="Image Preview" class="img-thumbnail mt-2" style="display: none; max-height: 200px;" />
                    <span class="text-danger" asp-validation-for="Product.MainImg"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Product.Price" class="form-label">Price</label>
                    <input type="number" class="form-control" asp-for="Product.Price">
                    <span class="text-danger" asp-validation-for="Product.Price"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Product.Quantity" class="form-label">Quantity</label>
                    <input type="number" class="form-control" asp-for="Product.Quantity">
                    <span class="text-danger" asp-validation-for="Product.Quantity"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Product.Discount" class="form-label">Discount</label>
                    <input type="number" class="form-control" asp-for="Product.Discount">
                    <span class="text-danger" asp-validation-for="Product.Discount"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Product.CategoryId" class="form-label">Category</label>
                    <select class="form-select" asp-for="Product.CategoryId" asp-items="Model.Categories">
                        <option disabled selected>-- Select Category --</option>
                    </select>
                    <span class="text-danger" asp-validation-for="Product.CategoryId"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Product.BrandId" class="form-label">Brand</label>
                    <select class="form-select" asp-for="Product.BrandId" asp-items="Model.Brands">
                        <option disabled selected>-- Select Brand --</option>
                    </select>
                    <span class="text-danger" asp-validation-for="Product.BrandId"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Product.Status" class="form-label">Status</label>
                    <select asp-for="Product.Status" class="form-select">
                        <option value="true">Active</option>
                        <option value="false">Inactive</option>
                    </select>
                    <span class="text-danger" asp-validation-for="Product.Status"></span>
                </div>

                <button type="submit" class="btn btn-primary">Submit</button>
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            </form>
        </div>
    </div>
</div>

<script>
    function previewImage(event) {
        const input = event.target;
        const preview = document.getElementById('imagePreview');

        if (input.files && input.files[0]) {
            const reader = new FileReader();
            reader.onload = function (e) {
                preview.src = e.target.result;
                preview.style.display = 'block';
            };
            reader.readAsDataURL(input.files[0]);
        }
    }
</script>